{
  "name": "nextjs-starter-kit",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Triều Minh",
    "email": "ttrieuminh1998@gmail.com",
    "url": "https://github.com/trieuminh98"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trieuminh98/nextjs-starter-kit"
  },
  "homepage": "https://github.com/trieuminh98/nextjs-starter-kit",
  "bugs": {
    "url": "https://github.com/trieuminh98/nextjs-starter-kit/issues"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 4000",
    "build": "next build --turbopack",
    "start": "next start",
    "serve": "next build && next start -p 4000",
    "lint": "eslint .",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "svgo": "svgo -rf ./public -o ./public",
    "format": "prettier . --write --experimental-cli",
    "type-check": "tsc --noEmit",
    "next-gen-type": "next typegen && npm run type-check",
    "knip": "knip",
    "fta": "fta src",
    "clean": "node scripts/clean.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "dependencies": {
    "@lukemorales/query-key-factory": "^1.3.4",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-query-devtools": "^5.85.5",
    "axios": "^1.11.0",
    "camelcase-keys": "^9.1.3",
    "fta-cli": "^3.0.0",
    "jotai": "^2.13.1",
    "jotai-devtools": "^0.12.0",
    "js-cookie": "^3.0.5",
    "next": "15.5.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-error-boundary": "^6.0.0",
    "react-scan": "^0.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.83.1",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.7",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "husky": "^9.1.7",
    "knip": "^5.63.0",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "svgo": "^4.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.7"
  }
}
