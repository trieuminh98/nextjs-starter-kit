{
  "name": "nextjs-starter-kit",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Triều Minh",
    "email": "ttrieuminh1998@gmail.com",
    "url": "https://github.com/trieuminh98"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trieuminh98/nextjs-starter-kit"
  },
  "homepage": "https://github.com/trieuminh98/nextjs-starter-kit",
  "bugs": {
    "url": "https://github.com/trieuminh98/nextjs-starter-kit/issues"
  },
  "scripts": {
    "dev": "next dev -p 4000",
    "analyze": "next experimental-analyze",
    "build": "next build",
    "start": "next start",
    "serve": "next build && next start -p 4000",
    "lint": "oxlint .",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "svgo": "svgo -rf ./public -o ./public",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "type-check": "tsc --noEmit",
    "next-gen-type": "next typegen && npm run type-check",
    "clean": "node scripts/clean.ts",
    "docker:build": "docker compose build app",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:rebuild": "docker compose build --no-cache app && docker compose up -d"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxfmt --write",
      "oxlint --fix"
    ]
  },
  "dependencies": {
    "@bprogress/next": "^3.2.12",
    "@tanstack/query-core": "5.90.5",
    "@tanstack/react-query": "5.90.5",
    "@tanstack/react-query-devtools": "5.90.2",
    "axios": "^1.11.0",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "change-case": "^5.4.4",
    "jotai": "^2.15.1",
    "jotai-devtools": "^0.13.0",
    "js-cookie": "^3.0.5",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "^6.0.0",
    "react-scan": "^0.4.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tailwindcss/postcss": "^4",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.39.0",
    "svgo": "^4.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.0.0"
  }
}
